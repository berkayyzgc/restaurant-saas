generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id             Int            @id @default(autoincrement())
  name           String
  city           String
  createdAt      DateTime       @default(now())
  address        String
  description    String?
  phone          String
  updatedAt      DateTime       @updatedAt
  userId         Int
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  tables         Table[]
  tableSessions  TableSession[]
  user           User           @relation(fields: [userId], references: [id])
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurants Restaurant[]
}

model MenuCategory {
  id           Int        @id @default(autoincrement())
  name         String
  restaurantId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]
}

model MenuItem {
  id           Int          @id @default(autoincrement())
  name         String
  price        Float
  description  String?
  isAvailable  Boolean      @default(true)
  categoryId   Int
  restaurantId Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  category     MenuCategory @relation(fields: [categoryId], references: [id])
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  orderItems   OrderItem[]
}

model Table {
  id            Int            @id @default(autoincrement())
  name          String
  qrToken       String?        @unique
  restaurantId  Int
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tableSessions TableSession[]
}

enum TableSessionStatus {
  OPEN
  CLOSED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  
}

enum ServiceRequestType {
  CALL_WAITER
  REQUEST_BILL
}

enum ServiceRequestStatus {
  PENDING
  COMPLETED
  CANCELLED
}


enum PaymentMethod {
  ONLINE
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model TableSession {
  id           Int                @id @default(autoincrement())
  tableId      Int
  restaurantId Int
  status       TableSessionStatus @default(OPEN)
  openedAt     DateTime           @default(now())
  closedAt     DateTime?
  updatedAt    DateTime           @updatedAt

  table      Table      @relation(fields: [tableId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]
  payments   Payment[]
  serviceRequests ServiceRequest[]
}

model Order {
  id             Int                @id @default(autoincrement())
  tableSessionId Int
  status         OrderStatus        @default(PENDING)
  paymentStatus  OrderPaymentStatus @default(UNPAID)
  note           String?
  totalPrice     Decimal            @db.Decimal(10, 2)

  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?
  preparingAt DateTime?
  readyAt     DateTime?
  servedAt    DateTime?
  cancelledAt DateTime?
  paidAt      DateTime?
  updatedAt   DateTime  @updatedAt

  tableSession TableSession @relation(fields: [tableSessionId], references: [id])
  items        OrderItem[]
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  menuItemId Int
  itemName   String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  note       String?
  createdAt  DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model Payment {
  id                Int           @id @default(autoincrement())
  tableSessionId    Int
  amount            Decimal       @db.Decimal(10, 2)
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  keepSessionOpen   Boolean       @default(true)
  providerPaymentId String?
  createdAt         DateTime      @default(now())
  completedAt       DateTime?
  updatedAt         DateTime      @updatedAt

  tableSession TableSession @relation(fields: [tableSessionId], references: [id])
}

model ServiceRequest {
  id             Int                  @id @default(autoincrement())
  tableSessionId Int
  type           ServiceRequestType
  status         ServiceRequestStatus @default(PENDING)
  createdAt      DateTime             @default(now())
  completedAt    DateTime?
  updatedAt      DateTime             @updatedAt

  tableSession TableSession @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
}